    "process": {
      "eyebrow": "How I work",
      "headline": "A simple, direct, reviewable process.",
      "text": "",
      "steps": [
        {
          "title": "Briefing + raw",
          "text": "Send me the footage and we get aligned, whether through a quick WhatsApp chat or a more detailed meeting to close a package, define the intention, and set the deadline. You choose the format, I adapt."
        },
        {
          "title": "==Dirty work==",
          "text": "While I edit, you create. No worrying about the time-consuming part, no wasting time inside software. You focus on what matters: producing more content. I handle the rest."
        },
        {
          "title": "Open communication",
          "text": "Throughout the whole project, we keep talking about the video. Review is included, so if something needs adjustment or a new idea comes up, just say the word. I am here until the video is exactly how you imagined it."
        },
        {
          "title": "Final delivery",
          "text": "Video ready, on the agreed deadline, in high quality, and prepared to publish right away. No surprises, no extra work on your side. Just hit publish."
        }
      ]
    },
